# ═══════════════════════════════════════════════
#  E-Commerce Microservices - Environment Variables
# ═══════════════════════════════════════════════

# ─── Product Catalog DB ───
CATALOG_DB_HOST=product-catalog-db
CATALOG_DB_PORT=5432
CATALOG_DB_NAME=product_catalog
CATALOG_DB_USER=catalog_user
CATALOG_DB_PASSWORD=catalog_pass

# ─── Product Inventory DB ───
INVENTORY_DB_HOST=product-inventory-db
INVENTORY_DB_PORT=5432
INVENTORY_DB_NAME=product_inventory
INVENTORY_DB_USER=inventory_user
INVENTORY_DB_PASSWORD=inventory_pass

# ─── Order Management DB ───
ORDER_DB_HOST=order-management-db
ORDER_DB_PORT=5432
ORDER_DB_NAME=order_management
ORDER_DB_USER=order_user
ORDER_DB_PASSWORD=order_pass

# ─── Profile Management DB ───
PROFILE_DB_HOST=profile-management-db
PROFILE_DB_PORT=5432
PROFILE_DB_NAME=profile_management
PROFILE_DB_USER=profile_user
PROFILE_DB_PASSWORD=profile_pass

# ─── Shipping & Handling DB ───
SHIPPING_DB_HOST=shipping-handling-db
SHIPPING_DB_PORT=5432
SHIPPING_DB_NAME=shipping_handling
SHIPPING_DB_USER=shipping_user
SHIPPING_DB_PASSWORD=shipping_pass

# ─── Contact Support DB ───
SUPPORT_DB_HOST=contact-support-db
SUPPORT_DB_PORT=5432
SUPPORT_DB_NAME=contact_support
SUPPORT_DB_USER=support_user
SUPPORT_DB_PASSWORD=support_pass

# ─── JWT ───
JWT_SECRET=ecommerce-microservices-jwt-secret-key-2024

# ─── Inter-Service URLs (internal Docker network) ───
PRODUCT_SERVICE_URL=http://product-catalog:3001
INVENTORY_SERVICE_URL=http://product-inventory:3002
ORDER_SERVICE_URL=http://order-management:3003
PROFILE_SERVICE_URL=http://profile-management:3004
SHIPPING_SERVICE_URL=http://shipping-handling:3005
SUPPORT_SERVICE_URL=http://contact-support:3006

# ─── Frontend ───
VITE_API_BASE_URL=/api
